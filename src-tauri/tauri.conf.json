{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "trimo",
  "version": "0.1.2",
  "identifier": "com.bhd71.trimo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "focus": true,
        "title": "Trimo",
        "alwaysOnTop": false,
        "backgroundColor": "#111111"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
