{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "trimo",
  "version": "0.1.13",
  "identifier": "com.bhd71.trimo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "focus": true,
        "title": "Trimo",
        "alwaysOnTop": false,
        "backgroundColor": "#111111"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1MjdBMkFCMkZBNTJCOTMKUldTVEs2VXZxNkluUmJ5WTV2ejNvenkrd1NyNnFqS0ZaL1JOR3RGdlNiQTB3UUNLWFNxNTJSVlgK",
      "endpoints": [
        "https://github.com/bhd71/trimo/releases/latest/download/latest.json"
      ]
    }
  }
}
